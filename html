@app.route("/", methods=["GET", "POST"])
def index():
    texto = ""
    resultado = False
    titulo_resultado = ""
    descricao = ""
    selo = ""
    classe = ""
    porcentagem = 50
    frase_meme = ""

    frases_positivas = [
        "A energia bateu forte: isso tem cara de resenha positiva daquelas.",
        "O sistema apitou bonito: possibilidade alta de clima bom e risada solta.",
