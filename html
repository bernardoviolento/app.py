        "Isso aqui passou no teste do entretenimento. Tá com perfume de resenha memorável.",
    ]

    frases_neutras = [
        "O sistema sentiu insegurança na vibe. Pode virar resenha, mas ainda tá no quase.",
        "Foi detectada pouca pressão de entretenimento. Precisa de mais energia de grupo.",
        "No momento, o texto ainda não exala resenha positiva com força total.",
        "A máquina hesitou. Tá faltando aquele tempero que faz todo mundo falar: agora foi.",
    ]

    frases_meme = [
        "isso foi muito six seven das ideias",
        "o detector sentiu a aura da resenha no ar",
        "clima de meme aplicado com sucesso",
        "a tropa estatística analisou e deixou passar",
        "vibes elevadas para nível de resenha premium",
        "caos, brilho e entretenimento detectados",
    ]

    if request.method == "POST":
        texto = request.form.get("texto", "").strip()
        resultado = True

        positivo = random.choice([True, False])

        if positivo:
            titulo_resultado = "Resultado: forte chance de salada foguete foguete"
            descricao = random.choice(frases_positivas)
            selo = "APROVADO PELO SENSOR DE RESENHA"
            classe = "positive"
            porcentagem = 50
        else:
            titulo_resultado = "Resultado: a resenha está sem aura, saia daqui beta"
            descricao = random.choice(frases_neutras)
            selo = "SUSPEITA DE POUCA RESENHA"
            classe = "neutral"
            porcentagem = 50

        frase_meme = random.choice(frases_meme)

    return render_template_string(
        HTML,
        texto=texto,
        resultado=resultado,
        titulo_resultado=titulo_resultado,
        descricao=descricao,
        selo=selo,
        classe=classe,
        porcentagem=porcentagem,
        frase_meme=frase_meme,
    )


if __name__ == "__main__":
    app.run(debug=True)
